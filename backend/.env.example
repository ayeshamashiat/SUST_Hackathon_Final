# Postgres superuser (used only by the postgres container itself and db-init)
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres

# Per-provider + shared database credentials (created by db-init/init-databases.sh).
# Each service only ever receives the credential for the database(s) it owns.
BKASH_DB_PASSWORD=bkash_pw
NAGAD_DB_PASSWORD=nagad_pw
ROCKET_DB_PASSWORD=rocket_pw
SHARED_DB_PASSWORD=shared_pw
SYNC_SERVICE_DB_PASSWORD=sync_pw

# Full connection strings (host is the docker-compose service name "postgres").
# provider-api uses the BKASH_/NAGAD_/ROCKET_ ones (read-write, own DB only).
BKASH_DATABASE_URL=postgresql://bkash_service:bkash_pw@postgres:5432/bkash_db
NAGAD_DATABASE_URL=postgresql://nagad_service:nagad_pw@postgres:5432/nagad_db
ROCKET_DATABASE_URL=postgresql://rocket_service:rocket_pw@postgres:5432/rocket_db

# aggregator-api's future credential (Phase 5) - SELECT-only on shared_db by
# Postgres grant, not just by convention. Never used for provider databases.
SHARED_DATABASE_URL=postgresql://shared_service:shared_pw@postgres:5432/shared_db

# sync-service's own credentials: read-only on the three provider databases,
# read-write (sole writer + schema owner) on shared_db. Deliberately separate
# from the BKASH_/NAGAD_/ROCKET_ URLs above - a different Postgres role, not
# just a different connection string to the same role.
SYNC_BKASH_DATABASE_URL=postgresql://sync_service:sync_pw@postgres:5432/bkash_db
SYNC_NAGAD_DATABASE_URL=postgresql://sync_service:sync_pw@postgres:5432/nagad_db
SYNC_ROCKET_DATABASE_URL=postgresql://sync_service:sync_pw@postgres:5432/rocket_db
SYNC_SHARED_DATABASE_URL=postgresql://sync_service:sync_pw@postgres:5432/shared_db

# Sync service polling interval, and how many seconds a provider's source
# data can go without updating before that provider is marked "delayed"
# rather than "ok" (must stay comfortably above the poll interval so normal
# poll jitter never triggers a false delayed reading).
SYNC_POLL_INTERVAL_SECONDS=10
SYNC_STALE_AFTER_SECONDS=60

# OpenAI (used by aggregator-api's services/llm.py, added Phase 5) - never commit a real key.
# Leave blank for local dev; a mock generator is used when this is empty.
OPENAI_API_KEY=
